# Docker Environment Configuration — TEMPLATE FILE
# ⚠️  DO NOT put real secrets here. Set these in your deployment platform's env vars.
# Copy this to .env locally and fill in your real values (never commit .env)

# ======================
# Authentication Settings
# ======================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# GitHub OAuth (Optional) — create at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# LinkedIn OAuth configurations — create at https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ======================
# API Keys
# ======================
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
MISTRAL_API_KEY=your-mistral-api-key
GOOGLE_API_KEY=your-google-gemini-api-key

# ======================
# LLM Configuration
# ======================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# ======================
# Embedding Configuration
# ======================
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ======================
# Vector Database
# ======================
VECTOR_DB_TYPE=qdrant
QDRANT_COLLECTION=code_chunks
QDRANT_USE_MEMORY=false

# ======================
# Feature Flags
# ======================
ENABLE_ML_ANALYSIS=true
ENABLE_DL_ANALYSIS=false
ENABLE_LLM_AGENTS=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_CVE_DETECTION=true
ENABLE_SECURITY_REPORTING=true

# ======================
# Static Analysis Tools
# ======================
ENABLE_BANDIT=true
ENABLE_SEMGREP=true
ENABLE_PYLINT=false
ENABLE_RUFF=true

# ======================
# Performance
# ======================
MAX_WORKERS=4
CACHE_EMBEDDINGS=true
